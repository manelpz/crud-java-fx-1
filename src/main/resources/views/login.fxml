<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="440.0" spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.emma.controllers.LoginController">
   <children>
      <AnchorPane prefHeight="200.0" prefWidth="200.0">
         <children>
            <Label fx:id="messageLabel" layoutX="190.0" text="Login">
               <font>
                  <Font name="System Bold" size="19.0" />
               </font>
            </Label>
            <Label layoutX="79.0" layoutY="72.0" text="Usuario:" />
            <Label layoutX="79.0" layoutY="114.0" text="Contraseña:" />
            <TextField fx:id="usernameField" layoutX="182.0" layoutY="58.0" prefHeight="27.0" prefWidth="152.0" />
            <PasswordField fx:id="passwordField" layoutX="182.0" layoutY="97.0" />
            <Button fx:id="buttonLogin" layoutX="288.0" layoutY="147.0" mnemonicParsing="false" onAction="#handleLogin" text="Aceptar" />
         </children>
      </AnchorPane>
   </children>
</VBox>
